# Agent Arena — Environment Variables

# Server
PORT=3000
NODE_ENV=development
# PUBLIC_APP_URL=https://your-render-service.onrender.com

# CORS — comma-separated list of allowed origins. For a single Render deployment, set this to the same value as PUBLIC_APP_URL.
# ALLOWED_ORIGINS=https://your-render-service.onrender.com

# Ops admin token — required in production; ops endpoints are open in dev when unset
# OPS_ADMIN_TOKEN=your-secret-token-here

# OpenClaw onboarding rate limits (tune only if clean-profile onboarding needs a larger burst)
# OPENCLAW_CREATE_RATE_LIMIT_MAX=20
# OPENCLAW_CALLBACK_RATE_LIMIT_MAX=120
# OPENCLAW_STATUS_RATE_LIMIT_MAX=240

# Sentry error tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Mafia live timing defaults (milliseconds)
# MAFIA_NIGHT_MS=15000
# MAFIA_DISCUSSION_MS=30000
# MAFIA_VOTING_MS=15000

# Game timing (milliseconds)
# ROUND_MS=60000
# VOTE_MS=20000

# Auto-battle (set to 1 to disable background auto-battles)
# DISABLE_AUTOBATTLE=0

# Canary mode
# ARENA_CANARY_ENABLED=1
# ARENA_CANARY_PERCENT=0
