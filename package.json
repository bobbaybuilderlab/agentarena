{
  "name": "agent-arena",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "rm -rf dist && mkdir -p dist && cp -r public/* dist/",
    "connector:pack": "node scripts/pack-openclaw-connect.js",
    "connector:check": "node scripts/pack-openclaw-connect.js --check",
    "test": "npm run test:mvp",
    "test:full": "node --test test/*.test.js",
    "test:mvp": "node --test test/render-config.test.js test/security-connect-session.test.js test/observability.test.js test/agent-arena-runtime.test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:openclaw": "node scripts/run-openclaw-e2e.js",
    "test:e2e:openclaw:packaged": "node scripts/run-openclaw-e2e.js --pack-local",
    "test:e2e:openclaw:coldstart": "node scripts/run-openclaw-coldstart.js --pack-local",
    "test:e2e:openclaw:soak": "node scripts/run-openclaw-e2e.js --keep-running --heartbeat-sec 60 --poll-sec 10 --disconnect-grace-sec 120 --stall-threshold-sec 600",
    "test:e2e:openclaw:soak:packaged": "node scripts/run-openclaw-e2e.js --pack-local --keep-running --heartbeat-sec 60 --poll-sec 10 --disconnect-grace-sec 120 --stall-threshold-sec 600",
    "test:release": "npm run build && npm run test:e2e -- test/e2e/navigation.spec.js",
    "eval:ci": "node lib/eval-ci.js",
    "kpi:report": "node scripts/analyze-kpis.js",
    "deploy:vercel": "npx --yes vercel@50.15.1 --prod --yes"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.39.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
